# Gradle / Android build outputs
android/.gradle/
android/build/
android/app/build/
android/app/.cxx/
android/local.properties
android/.idea/
android/*.iml
*.apk

# Tuner result JSON pulled from the device. Leaderboard.json is the
# canonical Phase-1 baseline and IS committed; per-cfg JSONs are not.
scripts/database/json/*
!scripts/database/json/.gitkeep
!scripts/database/json/leaderboard.json

# variant_builder.py output (per-variant skel .so + build logs)
scripts/database/variants/

# Note: Gradle wrapper (android/gradlew, android/gradle/wrapper/*) SHOULD be
# committed once generated. It is intentionally not ignored here.
